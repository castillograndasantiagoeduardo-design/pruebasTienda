@model PruebaBackendTienda.Models.ViewModels.CrearProductoViewModel

@{
    ViewData["Title"] = "Agregar Producto";
}

<div class="container py-4" style="max-width:720px">
    <div class="d-flex align-items-center gap-2 mb-4">
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left"></i>
        </a>
        <h5 class="mb-0 fw-bold">Agregar Nuevo Producto</h5>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-4">
            <form asp-action="Crear" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

                @* Nombre *@
                <div class="mb-3">
                    <label asp-for="Nombre" class="form-label fw-semibold">Nombre del producto</label>
                    <input asp-for="Nombre" class="form-control" placeholder="Ej: Empanada de pipián" />
                    <span asp-validation-for="Nombre" class="text-danger small"></span>
                </div>

                @* Precio + Stock *@
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="Precio" class="form-label fw-semibold">Precio ($)</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input asp-for="Precio" type="number" step="0.01" min="0"
                                   class="form-control" placeholder="0.00" />
                        </div>
                        <span asp-validation-for="Precio" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Stock" class="form-label fw-semibold">Stock inicial</label>
                        <input asp-for="Stock" type="number" min="0" class="form-control" placeholder="0" />
                        <span asp-validation-for="Stock" class="text-danger small"></span>
                    </div>
                </div>

                @* Categoría *@
                <div class="mb-3">
                    <label asp-for="Id_Categoria" class="form-label fw-semibold">Categoría</label>
                    <select asp-for="Id_Categoria" class="form-select"
                            asp-items="@ViewBag.Categorias">
                        <option value="">-- Selecciona una categoría --</option>
                    </select>
                    <span asp-validation-for="Id_Categoria" class="text-danger small"></span>
                </div>

                @* Descripción *@
                <div class="mb-3">
                    <label asp-for="Descripcion" class="form-label fw-semibold">
                        Descripción <span class="text-muted fw-normal">(opcional)</span>
                    </label>
                    <textarea asp-for="Descripcion" class="form-control" rows="3"
                              placeholder="Describe brevemente el producto..."></textarea>
                </div>

                @* Imagen *@
                <div class="mb-4">
                    <label asp-for="Imagen" class="form-label fw-semibold">
                        Imagen <span class="text-muted fw-normal">(opcional)</span>
                    </label>
                    <input asp-for="Imagen" type="file" class="form-control"
                           accept="image/png,image/jpeg,image/webp"
                           onchange="previsualizarImagen(event)" />
                    <div id="contenedorPreview" class="mt-2 d-none">
                        <img id="preview" src="#" alt="Vista previa"
                             class="rounded border" style="max-height:160px; max-width:100%;" />
                    </div>
                </div>

                @* Botones *@
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success px-4">
                        <i class="bi bi-check-circle me-1"></i>Guardar producto
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function previsualizarImagen(event) {
            const file = event.target.files[0];
            const preview = document.getElementById('preview');
            const contenedor = document.getElementById('contenedorPreview');
            if (file) {
                preview.src = URL.createObjectURL(file);
                contenedor.classList.remove('d-none');
            } else {
                contenedor.classList.add('d-none');
            }
        }
    </script>
}
